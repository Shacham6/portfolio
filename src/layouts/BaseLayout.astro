---
import "../styles/global.css";
const { title } = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title ?? "Portfolio"} — Shacham's Projects</title>
    <meta name="description" content="Side projects by Shacham" />
  </head>
  <body>
    <header>
      <nav>
        <a href="/" class="logo">← Home</a>
      </nav>
    </header>

    <main>
      <slot />
    </main>

    <footer>
      <p>© {new Date().getFullYear()} Shacham — built with Astro</p>
    </footer>
  </body>
</html>

<style>
  * {
    box-sizing: border-box;
    margin: 0;
    padding: 0;
  }

  body {
    font-family: system-ui, -apple-system, sans-serif;
    background: #0f0f0f;
    color: #e8e8e8;
    min-height: 100vh;
    display: flex;
    flex-direction: column;
  }

  header {
    padding: 1.5rem 2rem;
  }

  nav {
    max-width: 1200px;
    margin: 0 auto;
    width: 100%;
  }

  .logo {
    color: #888;
    text-decoration: none;
    font-size: 0.95rem;
    transition: color 0.2s;
  }

  .logo:hover {
    color: #fff;
  }

  main {
    flex: 1;
    max-width: 1200px;
    margin: 0 auto;
    padding: 0 2rem 4rem;
    width: 100%;
  }

  footer {
    text-align: center;
    padding: 2rem;
    color: #555;
    font-size: 0.85rem;
  }
</style>
