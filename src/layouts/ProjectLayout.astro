---
import BaseLayout from "./BaseLayout.astro";
import Gallery from "../components/Gallery.astro";
import Carousel from "../components/Carousel.astro";
import VideoEmbed from "../components/VideoEmbed.astro";
import { render } from "astro:content";
const { entry } = Astro.props;
const { title, description, gallery, video, tags, date, games } = entry.data;
const { Content } = await render(entry);
---

<BaseLayout title={title}>
  <article class="project">
    <header class="project-header">
      <a href={import.meta.env.BASE_URL} class="back-link">← All projects</a>
      <h1>{title}</h1>
      <p class="meta">
        <time datetime={date.toISOString()}>
          {date.toLocaleDateString("en-US", { year: "numeric", month: "long" })}
        </time>
        {tags.length > 0 && (
          <span class="tags">
            {tags.map((t) => <span class="tag">{t}</span>)}
          </span>
        )}
      </p>
      <p class="description">{description}</p>
    </header>

    {video && <VideoEmbed url={video} />}

    {gallery && gallery.length > 0 && <Gallery images={gallery} />}

    <div class="content">
      <Content />
    </div>

    {games && games.length > 0 && (
      <div class="games-section">
        {games.map((game) => (
          <section class="game">
            <div class="game-header">
              {game.thumbnail && (
                <img class="game-icon" src={game.thumbnail} alt="" />
              )}
              <h2>{game.name}</h2>
              {game.link && <a href={game.link} target="_blank" rel="noopener">taptap.io </a>}
            </div>
            {game.description && <p class="game-desc">{game.description}</p>}
            {game.gallery && game.gallery.length > 0 && <Carousel images={game.gallery} />}
          </section>
        ))}
      </div>
    )}
  </article>
</BaseLayout>

<style>
  .project {
    max-width: 800px;
    margin: 0 auto;
  }

  .project-header {
    margin-bottom: 2.5rem;
  }

  .back-link {
    display: inline-block;
    color: #888;
    text-decoration: none;
    font-size: 0.9rem;
    margin-bottom: 1.5rem;
    transition: color 0.2s;
  }

  .back-link:hover {
    color: #fff;
  }

  h1 {
    font-size: 2.2rem;
    font-weight: 700;
    margin-bottom: 0.5rem;
    line-height: 1.2;
  }

  .meta {
    color: #666;
    font-size: 0.9rem;
    margin-bottom: 1rem;
    display: flex;
    align-items: center;
    gap: 0.75rem;
    flex-wrap: wrap;
  }

  .tags {
    display: flex;
    gap: 0.4rem;
    flex-wrap: wrap;
  }

  .tag {
    background: #1a1a2e;
    color: #8888cc;
    padding: 0.15rem 0.6rem;
    border-radius: 4px;
    font-size: 0.8rem;
  }

  .description {
    font-size: 1.15rem;
    color: #aaa;
    line-height: 1.5;
  }

  .content {
    margin-top: 2.5rem;
    line-height: 1.7;
    font-size: 1.05rem;
    color: #ccc;
  }

  .content p {
    margin-bottom: 1rem;
  }

  .content h2 {
    margin: 2rem 0 0.5rem;
    font-size: 1.35rem;
  }

  .content ul,
  .content ol {
    padding-left: 1.5rem;
    margin-bottom: 1rem;
  }

  .content code {
    background: #1a1a1a;
    padding: 0.1rem 0.3rem;
    border-radius: 3px;
    font-size: 0.9em;
  }

  .content a {
    color: #6688ff;
  }

  .repo-link {
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
    margin-top: 0.5rem;
    padding: 0.3rem 0.7rem;
    background: #1a1a2e;
    border-radius: 6px;
    font-size: 0.85rem;
    color: #8888cc;
    text-decoration: none;
    transition: background 0.2s, color 0.2s;
  }

  .repo-link:hover {
    background: #252545;
    color: #aaaadd;
  }

  .repo-link svg {
    flex-shrink: 0;
  }

  .games-section {
    margin: 2.5rem 0;
  }

  .game {
    margin-bottom: 3rem;
    padding-bottom: 2rem;
    border-bottom: 1px solid #222;
  }

  .game:last-child {
    border-bottom: none;
  }

  .game-header {
    display: flex;
    align-items: center;
    gap: 1rem;
    margin-bottom: 0.75rem;
  }

  .game-icon {
    width: 64px;
    height: 64px;
    border-radius: 12px;
    object-fit: cover;
    flex-shrink: 0;
  }

  .game-header h2 {
    font-size: 1.5rem;
    font-weight: 600;
    margin: 0;
  }

  .game-header a {
    color: #6688ff;
    font-size: 0.9rem;
    text-decoration: none;
  }

  .game-header a:hover {
    text-decoration: underline;
  }

  .game-desc {
    color: #aaa;
    font-size: 1rem;
    line-height: 1.6;
    margin-bottom: 1.5rem;
  }
</style>
